# CRM-Luna - Cloud / Web

# ===== Backend shared =====
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_SECRET
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

# LunaCore database
NEON_LUNACORE_URL=jdbc:postgresql://HOST/DB?user=USER&password=PASS&sslmode=require&currentSchema=luna

# TotemAPI database
SPRING_DATASOURCE_URL=jdbc:postgresql://HOST/DB?user=USER&password=PASS&sslmode=require&currentSchema=luna

# TotemAPI optional integrations
TOTEM_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTES
WEBHOOK_GHL_TOKEN=
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_WEBHOOK_SECRET=

# ===== TotemUI / Vercel =====
TOTEM_API_PROXY_URL=https://api.seu-dominio.com
NEXT_PUBLIC_API_URL=https://api.seu-dominio.com
NEXT_PUBLIC_APP_MODE=web-only
NEXT_PUBLIC_VIDEO_TENANT_ID=tenant-1
NEXT_PUBLIC_VIDEO_AUTO_CACHE=false
